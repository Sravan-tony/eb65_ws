  <joint name="base_rotation_joint" type="revolute">
    <origin xyz="0.0 0.0 0.13" rpy="0.0 0.0 0.0" />
    <parent link="base_link" />
    <child link="base_rotation_link" />
    <axis xyz="0.0 0.0 1.0" />
    <limit lower="${base_rotation_lower}" upper="${base_rotation_upper}" effort="${base_rotation_effort}" velocity="${base_rotation_velocity}" />
  </joint>

  <joint name="base_joint_1" type="fixed">
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
