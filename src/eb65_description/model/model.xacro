    <parent link="gripper_support_link_2" />
    <child link="bottom_finger" />
    <axis xyz="0.0 1.0 0.0" />
    <limit lower="${prismatic_lower}" upper="${prismatic_upper}" effort="${prismatic_effort}" velocity="${prismatic_velocity}" />
    <mimic joint="gripper_joint" multiplier="0.02" offset="0" />
