<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="parameters.xacro" />

  <!-- ==================== MATERIALS ==================== -->
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1" />
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1" />
  </material>
  <material name="white">
    <color rgba="1 1 1 1" />
  </material>

  <!-- ==================== BASE GROUP ==================== -->
  <!-- <link name="base_footprint">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="${base_footprint_mass}" />
      <inertia ixx="${base_footprint_inertia}" ixy="0" ixz="0" iyy="${base_footprint_inertia}" iyz="0" izz="${base_footprint_inertia}" />
    </inertial>
  </link> -->

  <link name="base_link">
    <inertial>
      <origin xyz="${base_link_origin}" rpy="0 0 0" />
      <mass value="${base_link_mass}" />
      <inertia ixx="${base_link_inertia}" ixy="0" ixz="0" iyy="${base_link_inertia}" iyz="0" izz="${base_link_inertia}" />
    </inertial>
    <visual>
      <origin xyz="-0.1 -0.1 0.0" rpy="0.0 0.0 0.0" />
      <geometry>
        <mesh filename="${base_mesh}" scale="${mesh_scale}" />
      </geometry>
      <material name="${material_blue}" />
    </visual>
    <collision>
      <origin xyz="-0.1 -0.1 0.0" rpy="0.0 0.0 0.0" />
      <geometry>
        <mesh filename="${base_mesh}" scale="${mesh_scale}" />
      </geometry>
    </collision>
  </link>

  <link name="base_rotation_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="${base_rotation_mass}" />
      <inertia ixx="${base_rotation_inertia}" ixy="0" ixz="0" iyy="${base_rotation_inertia}" iyz="0" izz="${base_rotation_inertia}" />
    </inertial>
    <visual>
      <origin xyz="0.1 -0.1 0.0" rpy="0.0 3.1416 0.0" />
      <geometry>
        <mesh filename="${base_rotation_mesh}" scale="${mesh_scale}" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.1 -0.1 0.0" rpy="0.0 3.1416 0.0" />
      <geometry>
        <mesh filename="${base_rotation_mesh}" scale="${mesh_scale}" />
      </geometry>
    </collision>
  </link>

  <link name="base_link_3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="${base_link_3_mass}" />
      <inertia ixx="${base_link_3_inertia}" ixy="0" ixz="0" iyy="${base_link_3_inertia}" iyz="0" izz="${base_link_3_inertia}" />
    </inertial>
    <visual>
      <origin xyz="0.1 -0.1 0.0" rpy="0.0 0.0 1.5708" />
